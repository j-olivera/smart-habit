# Environment Variables - Smart Habit Project
# Copiar a .env.local para desarrollo local

# PostgreSQL
POSTGRES_DB=smarthabit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=strong_password
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8080

# Frontend
FRONTEND_PORT=4200

# Ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3

# JWT
JWT_SECRET=super_secret_jwt_key_for_development_change_in_production